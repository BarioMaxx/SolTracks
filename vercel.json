{
  "domains": [
    "soltracks.bario.me"
  ],
  "env": {
    "DATABASE_URL": "@database_url",
    "SOLANA_RPC_URL": "@solana_rpc_url",
    "RESEND_API_KEY": "@resend_api_key",
